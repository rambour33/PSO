# Port d'écoute — Hostinger l'injecte automatiquement
PORT=3002

# URL publique du site (sans slash final)
# En local : laisser vide (auto-détecté)
# Sur Hostinger : https://tondomaine.com
BASE_URL=https://tondomaine.com

# Mot de passe du panneau /control
# Laisser vide pour désactiver la protection
CONTROL_PASSWORD=motdepasse-secret

# Clé secrète pour signer les cookies de session (32+ caractères aléatoires)
SESSION_SECRET=changez-moi-avec-une-longue-chaine-aleatoire
